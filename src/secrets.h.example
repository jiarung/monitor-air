#pragma once

#include <stdint.h>

// Template for secrets.h — copy this file to secrets.h and fill in real values.
// secrets.h is gitignored so your credentials never enter version control.
static const char* WIFI_SSID = "your-wifi-ssid";
static const char* WIFI_PASSWORD = "your-wifi-password";

// --- MQTT broker (server-side pipeline lives in broker/) ---
static const char*    MQTT_HOST      = "192.168.x.x"; // broker machine's LAN IP
static const uint16_t MQTT_PORT      = 1883;
// Device name: becomes the topic segment monitor-air/<id>/telemetry and the
// InfluxDB `device` tag. Allowed chars: A-Z a-z 0-9 _ - (no spaces / + #).
static const char*    MQTT_DEVICE_ID = "sensor-01";
// Optional broker auth — leave both empty for an anonymous broker.
static const char*    MQTT_USER      = "";
static const char*    MQTT_PASS      = "";
