# Copy to .env and fill in real values. .env is gitignored.
#
# Generate a strong admin token, e.g.:
#   openssl rand -hex 32

# --- InfluxDB first-boot setup (only consumed on the very first start) ---
DOCKER_INFLUXDB_INIT_MODE=setup
DOCKER_INFLUXDB_INIT_USERNAME=admin
DOCKER_INFLUXDB_INIT_PASSWORD=change-me-influx
DOCKER_INFLUXDB_INIT_ORG=monitor-air
DOCKER_INFLUXDB_INIT_BUCKET=sensors
DOCKER_INFLUXDB_INIT_RETENTION=0
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN=replace-with-openssl-rand-hex-32

# --- Grafana ---
GF_SECURITY_ADMIN_PASSWORD=change-me-grafana

# --- Plant-light controller (Tapo P110M) ---
TAPO_EMAIL=you@example.com           # TP-Link account (used for KLAP local auth)
TAPO_PASSWORD=change-me-tapo
TAPO_IP=192.168.1.50                 # P110M LAN IP — set a DHCP reservation
LIGHT_LOCATION=livingroom            # topic segment: monitor-air/<loc>/light/...
LIGHT_SENSOR_DEVICE=sensor-01        # which telemetry device's lux drives the light
LIGHT_TZ=Asia/Taipei                 # window is evaluated in this timezone
MQTT_HOST=mosquitto

# --- Telegram deadman alert (Grafana) ---
TELEGRAM_BOT_TOKEN=123456:ABC-replace-with-BotFather-token
TELEGRAM_CHAT_ID=123456789           # your numeric chat id (from getUpdates)
